{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "docker": {
    "enabled": true,
    "registryUrls": [
      "https://819004394028.dkr.ecr.us-east-1.amazonaws.com"
    ]
  },
  "hostRules": [
    {
      "hostType": "docker",
      "matchHost": "819004394028.dkr.ecr.us-east-1.amazonaws.com",
      "username": "AWS",  // Correct username for AWS ECR login
      "password": "${AWS_SECRET_ACCESS_KEY}"  // Use the secret access key as the password
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["Dockerfile"],
      "matchPackageNames": ["pythonbaseimage"],
      "versioning": "semver",
      "enabled": true
    }
  ]
}
