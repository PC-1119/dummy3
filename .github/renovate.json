{
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-breaking dependencies"
    },
    {
      "matchManagers": ["dockerfile"],
      "enabled": true,
      "versioning": "semantic",
      "updateTypes": ["patch", "minor", "major"],
      "registryUrls": ["https://819004394028.dkr.ecr.us-east-1.amazonaws.com"],
      "authToken": "AWS_ACCESS_KEY_ID=${{ secrets.AWS_ACCESS_KEY_ID }};AWS_SECRET_ACCESS_KEY=${{ secrets.AWS_SECRET_ACCESS_KEY }};"
    }
  ]
}
